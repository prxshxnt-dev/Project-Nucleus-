{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Nucleus Coaching Centre platform.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["student", "admin", "superadmin"],
          "description": "The user's role."
        },
        "planId": {
          "type": "string",
          "enum": ["free", "notes", "lectures", "premium"],
          "description": "The user's active subscription plan."
        },
        "authProvider": {
          "type": "string",
          "enum": ["Email", "Google"],
          "description": "The authentication provider used by the user."
        },
        "classGroup": {
          "type": "string",
          "enum": ["all", "6", "7", "8", "9", "10", "11", "12", "dropper"],
          "description": "The class/batch of the user."
        },
        "unlockedMaterials": {
          "type": "array",
          "items": { "type": "string" },
          "description": "The list of material IDs specifically unlocked for the user."
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": ["email", "role", "planId", "createdAt", "updatedAt"]
    },
    "Material": {
      "title": "Material",
      "description": "Educational content (Note, Lecture, etc.).",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["note", "lecture", "test"]
        },
        "url": {
          "type": "string"
        },
        "requiredPlan": {
          "type": "string",
          "enum": ["free", "notes", "lectures", "premium"]
        },
        "classGroup": {
          "type": "string",
          "enum": ["all", "6", "7", "8", "9", "10", "11", "12", "dropper", "jee", "neet"]
        },
        "classId": {
          "type": "string"
        },
        "subjectId": {
          "type": "string"
        },
        "chapterId": {
          "type": "string"
        },
        "materialType": {
          "type": "string",
          "enum": ["notes", "pyqs", "assignments", "dpps", "practice_sheets", "video_lectures", "formula_sheets", "mind_maps", "sample_papers", "tests"]
        },
        "fileUrl": {
          "type": "string"
        },
        "fileType": {
          "type": "string",
          "enum": ["pdf", "video", "image", "zip"]
        },
        "downloadCount": {
          "type": "number"
        },
        "bookmarks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "authorId": {
          "type": "string"
        }
      },
      "required": ["title", "description", "createdAt", "updatedAt", "authorId"]
    },
    "Class": {
      "title": "Class",
      "description": "Educative course standard.",
      "type": "object",
      "properties": {
        "className": { "type": "string" }
      },
      "required": ["className"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Educative course subject.",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "subjectName": { "type": "string" }
      },
      "required": ["classId", "subjectName"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "Subject specific chapter folder.",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "chapterName": { "type": "string" }
      },
      "required": ["subjectId", "chapterName"]
    },
    "ActiveDevice": {
      "title": "ActiveDevice",
      "description": "Information about a user active concurrent login session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "deviceId": { "type": "string" },
        "deviceModel": { "type": "string" },
        "userAgent": { "type": "string" },
        "ipAddress": { "type": "string" },
        "lastActive": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "forced_out"] }
      },
      "required": ["userId", "deviceId", "deviceModel", "userAgent", "ipAddress", "createdAt", "lastActive", "status"]
    },
    "LoginHistory": {
      "title": "LoginHistory",
      "description": "Dynamic history of user authentications.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "deviceId": { "type": "string" },
        "ipAddress": { "type": "string" },
        "timestamp": { "type": "string" },
        "deviceModel": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failure"] }
      },
      "required": ["userId", "email", "deviceId", "ipAddress", "timestamp", "deviceModel", "status"]
    },
    "SecurityViolation": {
      "title": "SecurityViolation",
      "description": "Threat assessment records for anti-screenshot and print shortcuts.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "violationType": { "type": "string" },
        "detail": { "type": "string" },
        "timestamp": { "type": "string" },
        "ipAddress": { "type": "string" },
        "deviceInfo": {
          "type": "object",
          "properties": {
            "userAgent": { "type": "string" },
            "platform": { "type": "string" },
            "language": { "type": "string" }
          },
          "required": ["userAgent", "platform", "language"]
        },
        "batchName": { "type": "string" },
        "status": { "type": "string", "enum": ["logged", "reviewed"] }
      },
      "required": ["userId", "email", "displayName", "violationType", "detail", "timestamp", "ipAddress", "deviceInfo", "batchName", "status"]
    },
    "Note": {
      "title": "Note",
      "description": "Student quick study note associated with educational material.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner userId of the note." },
        "email": { "type": "string" },
        "materialId": { "type": "string", "description": "Associated material document ID." },
        "materialTitle": { "type": "string" },
        "text": { "type": "string", "description": "Text content of the note input." },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "email", "materialId", "materialTitle", "text", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Stores user text thoughts on materials."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles, roles, and active plans."
    },
    "materials/{materialId}": {
      "schema": { "$ref": "#/entities/Material" },
      "description": "Stores educational materials."
    },
    "classes/{classId}": {
      "schema": { "$ref": "#/entities/Class" },
      "description": "Stores Class standards."
    },
    "subjects/{subjectId}": {
      "schema": { "$ref": "#/entities/Subject" },
      "description": "Stores Subject items belonging to Class."
    },
    "chapters/{chapterId}": {
      "schema": { "$ref": "#/entities/Chapter" },
      "description": "Stores chapter folders inside subjects."
    },
    "active_devices/{deviceId}": {
      "schema": { "$ref": "#/entities/ActiveDevice" },
      "description": "Syncs client active browsers."
    },
    "login_history/{logId}": {
      "schema": { "$ref": "#/entities/LoginHistory" },
      "description": "Traces account entry logins."
    },
    "security_violations/{violId}": {
      "schema": { "$ref": "#/entities/SecurityViolation" },
      "description": "Logs DRM block threats."
    }
  }
}
