rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if true; }

    function isSignedIn() {
      return request.auth != null;
    }

    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName', 'role', 'planId', 'createdAt', 'updatedAt'])
        && data.email is string && data.email.size() <= 200
        && data.displayName is string && data.displayName.size() <= 100
        && data.role in ['guest', 'student', 'admin', 'superadmin']
        && data.planId in ['free', 'notes', 'lectures', 'premium']
        && (!data.keys().hasAny(['classGroup']) || data.classGroup is string)
        && (!data.keys().hasAny(['unlockedMaterials']) || data.unlockedMaterials is list)
        && (!data.keys().hasAny(['mobile']) || data.mobile is string)
        && (!data.keys().hasAny(['onboardingCompleted']) || data.onboardingCompleted is bool)
        && (!data.keys().hasAny(['privacyAccepted']) || data.privacyAccepted is bool)
        && (!data.keys().hasAny(['termsAccepted']) || data.termsAccepted is bool)
        && (!data.keys().hasAny(['acceptedAt']) || data.acceptedAt is string)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidUserUpdate(data) {
      return data.keys().hasAll(['email', 'displayName', 'role', 'planId', 'createdAt', 'updatedAt'])
        && data.email is string && data.email.size() <= 200
        && data.displayName is string && data.displayName.size() <= 100
        && data.role in ['guest', 'student', 'admin', 'superadmin']
        && data.planId in ['free', 'notes', 'lectures', 'premium']
        && (!data.keys().hasAny(['classGroup']) || data.classGroup is string)
        && (!data.keys().hasAny(['unlockedMaterials']) || data.unlockedMaterials is list)
        && (!data.keys().hasAny(['mobile']) || data.mobile is string)
        && (!data.keys().hasAny(['onboardingCompleted']) || data.onboardingCompleted is bool)
        && (!data.keys().hasAny(['privacyAccepted']) || data.privacyAccepted is bool)
        && (!data.keys().hasAny(['termsAccepted']) || data.termsAccepted is bool)
        && (!data.keys().hasAny(['acceptedAt']) || data.acceptedAt is string)
        && data.createdAt == existing().createdAt
        && data.updatedAt == request.time;
    }

    function isValidMaterial(data) {
      return data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 5000
        && data.type in ['note', 'lecture', 'test']
        && (!data.keys().hasAny(['classGroup']) || data.classGroup is string)
        && (!data.keys().hasAny(['thumbnailUrl']) || data.thumbnailUrl is string)
        && (!data.keys().hasAny(['requiredPlan']) || data.requiredPlan is string)
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && data.authorId is string && data.authorId == request.auth.uid;
    }

    function isValidMaterialUpdate(data) {
        return data.title is string && data.title.size() <= 200
          && data.description is string && data.description.size() <= 5000
          && data.type in ['note', 'lecture', 'test']
          && (!data.keys().hasAny(['classGroup']) || data.classGroup is string)
          && (!data.keys().hasAny(['thumbnailUrl']) || data.thumbnailUrl is string)
          && (!data.keys().hasAny(['requiredPlan']) || data.requiredPlan is string)
          && data.createdAt == existing().createdAt
          && data.updatedAt == request.time
          && data.authorId == existing().authorId;
    }

    function getTier(plan) {
      return plan == 'premium' ? 3 : (plan == 'lectures' ? 2 : (plan == 'notes' ? 1 : 0));
    }

    function isValidActiveDevice(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.deviceId is string && data.deviceId.size() <= 128
        && data.deviceModel is string && data.deviceModel.size() <= 200
        && data.userAgent is string && data.userAgent.size() <= 500
        && data.ipAddress is string && data.ipAddress.size() <= 45
        && data.status in ['active', 'forced_out']
        && data.createdAt == request.time
        && data.lastActive == request.time;
    }

    function isValidActiveDeviceUpdate(data) {
      return data.userId == existing().userId
        && data.deviceId == existing().deviceId
        && data.deviceModel == existing().deviceModel
        && data.userAgent == existing().userAgent
        && data.ipAddress == existing().ipAddress
        && data.status in ['active', 'forced_out']
        && data.createdAt == existing().createdAt
        && data.lastActive == request.time;
    }

    function isValidLoginHistory(data) {
      return data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && data.deviceId is string && data.deviceId.size() <= 128
        && data.ipAddress is string && data.ipAddress.size() <= 45
        && data.deviceModel is string && data.deviceModel.size() <= 200
        && data.status in ['success', 'failure']
        && data.timestamp == request.time;
    }

    function isValidViolation(data) {
      return data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && data.displayName is string && data.displayName.size() <= 100
        && data.violationType is string && data.violationType.size() <= 100
        && data.detail is string && data.detail.size() <= 1000
        && data.ipAddress is string && data.ipAddress.size() <= 45
        && data.batchName is string && data.batchName.size() <= 100
        && data.status in ['logged', 'reviewed']
        && data.timestamp == request.time
        && data.deviceInfo is map;
    }

    function isValidNote(data) {
      return data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.email is string && data.email.size() <= 200
        && data.materialId is string && data.materialId.size() <= 128
        && data.materialTitle is string && data.materialTitle.size() <= 200
        && data.text is string && data.text.size() <= 10000
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidNoteUpdate(data) {
      return data.userId == existing().userId
        && data.email == existing().email
        && data.materialId == existing().materialId
        && data.materialTitle == existing().materialTitle
        && data.text is string && data.text.size() <= 10000
        && data.createdAt == existing().createdAt
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if (isSignedIn() && (request.auth.uid == userId || isAdmin())) || userId.matches('^student-.*');
      allow list: if isAdmin();
      
      allow create: if (
        isSignedIn() 
        && isValidId(userId) 
        && userId == request.auth.uid 
        && isValidUser(incoming())
        && (
          (incoming().role in ['guest', 'student'] && incoming().planId == 'free') ||
          (request.auth.token.email == 'meinkxun@gmail.com' && incoming().role == 'superadmin' && incoming().planId == 'premium')
        )
      ) || (
        !isSignedIn()
        && isValidId(userId)
        && userId.matches('^student-.*')
        && incoming().role == 'student'
        && incoming().planId == 'free'
      );

      allow update: if (
        (
          isSignedIn() 
          && isValidId(userId) 
          && isValidUserUpdate(incoming()) 
          && (
            (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt', 'streak', 'todayStudyMinutes', 'lastStudyDate', 'lastStreakDate', 'classGroup', 'onboardingCompleted', 'privacyAccepted', 'termsAccepted', 'acceptedAt']) && incoming().role == existing().role && incoming().planId == existing().planId) ||
            (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'role', 'planId', 'unlockedMaterials', 'classGroup', 'updatedAt', 'streak', 'todayStudyMinutes', 'lastStudyDate', 'lastStreakDate', 'onboardingCompleted', 'privacyAccepted', 'termsAccepted', 'acceptedAt']) && (request.auth.uid != userId || incoming().role == existing().role)) ||
            (request.auth.token.email == 'meinkxun@gmail.com' && request.auth.uid == userId)
          )
        ) || (
          !isSignedIn()
          && isValidId(userId)
          && userId.matches('^student-.*')
          && incoming().role == existing().role
          && incoming().planId == existing().planId
        )
      );

      allow delete: if isAdmin(); 
    }

    match /materials/{materialId} {
      allow get: if true;
      allow list: if true;
      
      allow create: if isAdmin() 
        && isValidId(materialId)
        && isValidMaterial(incoming());

      allow update: if isAdmin()
        && isValidId(materialId)
        && isValidMaterialUpdate(incoming())
        && incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'type', 'url', 'requiredPlan', 'updatedAt', 'classGroup', 'thumbnailUrl']);

      allow delete: if isAdmin();
    }

    match /mcq_tests/{testId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chapters/{chapterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /materials_secure/{materialId} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && materialId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('unlockedMaterials', []))
      );
      allow list, create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if docId != 'secure_bot' || isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /agreement_history/{historyId} {
      allow create: if isSignedIn() 
        && isValidId(historyId) 
        && incoming().userId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /mentors/{mentorId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /chatbot_sessions/{sessionId} {
      allow read, write: if true;
    }

    match /active_devices/{devId} {
      allow get, list, create, update, delete: if true;
    }

    match /login_history/{logId} {
      allow create: if isSignedIn() && isValidId(logId) && isValidLoginHistory(incoming()) && incoming().userId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /security_violations/{violId} {
      allow create: if isSignedIn() && isValidId(violId) && isValidViolation(incoming()) && incoming().userId == request.auth.uid;
      allow read: if isAdmin();
    }
    
    match /notes/{noteId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(noteId) && isValidNote(incoming());
      allow update: if isSignedIn() && isValidId(noteId) && isValidNoteUpdate(incoming()) && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && isValidId(noteId) && (existing().userId == request.auth.uid || isAdmin());
    }
  }
}
